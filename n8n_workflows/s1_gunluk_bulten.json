    {
      "parameters": {
        "jsCode": "const data = $input.first().json.content[0].text;\nconst users = data.data.users;\n\nreturn users.map(user => ({\n  json: {\n    chat_id: user.telegram_chat_id,\n    username: user.username,\n    full_name: user.full_name\n  }\n}));;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        208
      ],
      "id": "100d5e84-60a9-47d4-bcd2-248bff7b2847",
      "name": "Kullanıcıları Ayır"
    },
    {
      "parameters": {
        "jsCode": "const bulletinItems = $('Bülten Hazırla').all();\nconst userItems = $('Kullanıcıları Ayır').all();\nconst result = [];\n\nfor (let i = 0; i < bulletinItems.length; i++) {\n  const output = bulletinItems[i].json.output || '';\n  const chatId = userItems[i]?.json?.chat_id || '';\n  \n  const match = output.match(/SELECTED_IDS:\\[([^\\]]+)\\]/);\n  if (!match) {\n    result.push({ json: { user_chat_id: chatId, news_list: [] } });\n    continue;\n  }\n  \n  const ids = match[1].split(',').map(id => parseInt(id.trim()));\n  \n  // URL'leri output metninden parse et\n  const urlMatches = [...output.matchAll(/\\[Haberi Oku\\]\\((https?:\\/\\/[^\\)]+)\\)/g)];\n  const urls = urlMatches.map(m => m[1]);\n  \n  // Başlıkları parse et\n  const titleMatches = [...output.matchAll(/\\d️⃣\\s+(.+?)\\n/g)];\n  const titles = titleMatches.map(m => m[1].trim());\n  \n  // Kategori emoji → kategori adı mapping\n  const categoryMap = {\n    '💻': 'teknoloji', '🗳️': 'siyaset', '🎭': 'magazin',\n    '⚽': 'spor', '🔬': 'bilim', '💰': 'ekonomi',\n    '🎬': 'dizi_film', '🍽️': 'yemek', '🌍': 'dunya',\n    '🤖': 'ai', '🏥': 'saglik', '🎵': 'muzik'\n  };\n  \n  const newsList = ids.map((id, index) => ({\n    id: id,\n    title: titles[index] || `Haber ${index + 1}`,\n    category: 'genel',\n    url: urls[index] || ''\n  }));\n  \n  result.push({ json: { user_chat_id: chatId, news_list: newsList } });\n}\n\nreturn result;"
      },
